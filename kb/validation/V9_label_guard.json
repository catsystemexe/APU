{
  "schema_version": "V9_label_guard.v1",
  "normalization": {
    "lowercase": true,
    "remove_diacritics": true,
    "language": "cs",
    "match_strategy": "hybrid_stems_patterns_excludes"
  },
  "purpose": [
    "detect_interpretive_or_moral_language",
    "prevent_premature_inference",
    "separate_observation_from_interpretation",
    "redirect_user_to_observable_behavior",
    "runtime_validation_guard_for_extraction_layer"
  ],
  "global_do_not_infer": [
    "profile",
    "block",
    "zone"
  ],
  "risk_levels": {
    "LOW": "mírně interpretační nebo vágní jazyk",
    "MEDIUM": "výrazný hodnotící nebo kauzální výklad bez dostatku observables",
    "HIGH": "morální, diagnostizující, záměrový nebo silně stigmatizující label"
  },
  "collision_rules": {
    "prefer_false_negative": true,
    "pattern_beats_stem": true,
    "exclude_pattern_beats_all": true,
    "high_risk_beats_lower_risk": true,
    "multiple_hits_return_all_categories": true,
    "never_route_as_observable_behavior": true,
    "require_followup_observable_question": true
  },
  "validation_rules": [
    {
      "id": "VAL_001",
      "rule": "If label hit exists without concrete observable behavior, do not infer profile, block or zone."
    },
    {
      "id": "VAL_002",
      "rule": "If moral or intent attribution is detected, ask for exact words/actions/context."
    },
    {
      "id": "VAL_003",
      "rule": "If diagnostic label is detected, explicitly state that APU does not diagnose."
    },
    {
      "id": "VAL_004",
      "rule": "If absolutizing language is detected, ask about frequency, duration, situation and exceptions."
    },
    {
      "id": "VAL_005",
      "rule": "If parental or pedagogical defensive framing is detected, neutralize blame and return to shared observable description."
    }
  ],
