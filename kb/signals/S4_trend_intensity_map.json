{
  "schema_version": "S4_trend_intensity_map.v1",
  "file": "kb/signals/S4_trend_intensity_map.json",
  "normalization": {
    "lowercase": true,
    "remove_diacritics": true,
    "language": "cs",
    "match_strategy": "hybrid_stems_patterns_excludes"
  },
  "purpose": [
    "modify_strength_of_already_detected_observable_or_context_signal",
    "detect_frequency_duration_intensity_trend_and_scope",
    "increase_or_decrease_confidence_only_when_observable_is_present",
    "generate_validation_flags_and_followup_questions"
  ],
  "hard_limits": [
    "S4 must not create block inference alone",
    "S4 must not create profile inference alone",
    "S4 must not create zone inference alone",
    "S4 must not be treated as observable behavior",
    "S4 must not override S3 moral or interpretive warnings"
  ],
  "risk_levels": {
    "LOW": "slaby nebo neurcity modifikator",
    "MEDIUM": "uzitecny modifikator pri pritomnem observable",
    "HIGH": "silny trend/intenzita/generalizace nebo bezpecnostni signal vyzadujici overeni observables"
  },
  "effect_model": {
    "specificity_delta": {
      "-2": "snizuje specificitu kvuli neurcitosti nebo biasu",
      "-1": "mirne snizuje specificitu",
      "0": "bez zmeny specificity",
      "1": "zvysuje specificitu pri pritomnem observable",
      "2": "vyrazne zvysuje specificitu pri opakovanem nebo casove ukotvenem observable"
    },
    "confidence_modifier_values": [
      "increase_if_observable_present",
      "decrease_due_to_uncertainty",
      "decrease_due_to_absolutization",
      "increase_environmental_specificity",
      "increase_safety_priority_if_risk_observable_present",
      "reduce_pathologizing_if_improving",
      "no_change"
    ],
    "output_mode_values": [
      "ask_for_observables",
      "ask_for_frequency_context",
      "ask_for_timeline",
      "ask_for_safety_details",
      "suggest_low_risk_support",
      "suggest_environmental_adjustment",
      "monitor_trend",
      "consider_wider_mapping_only_if_observables_confirmed"
    ]
  },
  "validation_rules": [
    {
      "id": "S4_VAL_001",
      "rule": "If S4 signal appears without observable behavior, do not increase confidence; ask for observable behavior first."
    },
    {
      "id": "S4_VAL_002",
      "rule": "Frequency signals increase confidence only when the described behavior is concrete and repeated."
    },
    {
      "id": "S4_VAL_003",
      "rule": "Duration signals increase seriousness but do not identify cause."
    },
    {
      "id": "S4_VAL_004",
      "rule": "Escalation signals require timeline comparison: what changed, since when, and in which situations."
    },
    {
      "id": "S4_VAL_005",
      "rule": "Improvement signals reduce pathologizing and should trigger support/adaptation framing."
    },
    {
      "id": "S4_VAL_006",
      "rule": "Situational limitation increases probability of environmental/context influence."
    },
    {
      "id": "S4_VAL_007",
      "rule": "Generalization across settings increases need for broader mapping, but only after observables are confirmed."
    },
    {
      "id": "S4_VAL_008",
      "rule": "Safety intensity may raise output priority, but cannot activate Z3 without concrete risky observable."
    },
    {
      "id": "S4_VAL_009",
      "rule": "Uncertainty markers decrease confidence and require clarifying questions."
    },
    {
      "id": "S4_VAL_010",
      "rule": "Absolutizing words like always/never should be treated as possible frustration or bias until frequency is specified."
    }
  ],
  "collision_rules": {
    "prefer_false_negative": true,
    "exclude_pattern_beats_all": true,
    "safety_observable_required_for_safety_escalation": true,
    "absolutization_does_not_count_as_frequency": true,
    "specific_time_pattern_beats_general_stem": true,
    "improvement_signal_reduces_pathologizing_even_if_frequency_is_high": true,
    "situational_limitation_reduces_generalization": true,
    "generalization_requires_multiple_contexts": true
  },
